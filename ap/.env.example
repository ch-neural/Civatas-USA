# ─── Civatas-USA ───
# Isolates this stack from other Civatas checkouts on the same machine
# (e.g. Civatas-V01) so container names don't collide. Containers become
# civatas-usa-web-1, civatas-usa-api-1, …
COMPOSE_PROJECT_NAME=civatas-usa
DEFAULT_LOCALE=en
TZ=America/New_York

# ─── Web UI host port ───
# Host port for the Next.js web UI (container port stays 3000).
# Change if 3100 conflicts with another project on your machine.
WEB_PORT=3100

# ─── LLM Configuration ───
# DeepSeek is recommended as the cheapest provider that handles English
# political prompts well (~$3-5 per 100-agent x 30-day evolution run).
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# Optional: dual-vendor failover
LLM_API_KEY2=
LLM_MODEL2=
LLM_BASE_URL2=

# Provider-specific keys (only the one matching LLM_PROVIDER is required)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=

# ─── Serper (news search) ───
# Required for the news_intelligence pipeline; falls back gracefully if absent.
SERPER_API_KEY=

# ─── Election Database (Postgres) ───
ELECTION_DB_USER=civatas
ELECTION_DB_PASS=civatas2026
